.design-pkg/
.DS_Store

# Single repo-root env file (secrets) — never commit. The example IS tracked.
.env
.env.local
.env*.local
!.env.example

# Dependencies for any sub-project — installed locally, never committed.
node_modules/

# This repo is a container for independent sibling projects (main-app/, etc.).
# npm should run inside a sub-project, never at the repo root. Ignore stray
# artifacts from an accidental `npm install` run in the wrong directory.
/package-lock.json
/package.json
/main-app/main-app/
