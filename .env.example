# =============================================================================
# Zenemic — ONE env file for the WHOLE repo (backend services + Expo app)
# =============================================================================
# Copy this file to `.env.local` at the repo root and fill in real values.
# NEVER commit `.env.local`.
#
# Who reads what:
#   • backend (main-app + keyboard services) reads everything below EXCEPT the
#     EXPO_PUBLIC_* block — loaded by packages/shared/src/config/env.ts.
#   • the Expo app (main-app/) reads ONLY the EXPO_PUBLIC_* block — loaded by
#     main-app/app.config.js. The secrets above NEVER reach the app bundle.
#
# Keys marked [REQUIRED] must be set for the backend to boot. [OPTIONAL] keys
# gate an integration — if unset, the related endpoints return a clear
# "not configured" error instead of crashing, so you can bring things up
# incrementally.
# =============================================================================

# -----------------------------------------------------------------------------
# Core server (backend)
# -----------------------------------------------------------------------------
NODE_ENV=development
# Ports — the two backend services read this one file but listen on different
# ports, so there's no clash. (A platform-injected PORT overrides these.)
MAIN_APP_PORT=4000
KEYBOARD_PORT=4100
# Public base URL of the main-app backend (used to build OAuth redirect + webhook URLs).
API_BASE_URL=http://localhost:4000
# Comma-separated allowed CORS origins (only matters for the web client; native fetch ignores CORS).
CORS_ORIGINS=http://localhost:8081,http://localhost:19006
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Database — Supabase (PostgreSQL) — [REQUIRED]
# -----------------------------------------------------------------------------
# Prisma needs BOTH: DATABASE_URL = POOLED url (port 6543), DIRECT_URL = direct (5432).
# Supabase dashboard → "Connect" → ORMs / Prisma. Replace [PASSWORD]/[PROJECT-REF]/[REGION].
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
DIRECT_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres

# -----------------------------------------------------------------------------
# Auth — Supabase Auth — [REQUIRED] (backend verifies the access token)
# -----------------------------------------------------------------------------
SUPABASE_URL=https://[PROJECT-REF].supabase.co
# Service-role key — SECRET. Admin ops + token checks. NEVER ship to the client.
SUPABASE_SERVICE_ROLE_KEY=
# ONLY for legacy HS256 projects. Leave BLANK to verify via JWKS (modern default).
SUPABASE_JWT_SECRET=
# Internal secret for signing short-lived Google OAuth "state" tokens.
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
APP_SECRET=

# -----------------------------------------------------------------------------
# Anthropic — core AI [REQUIRED]
# -----------------------------------------------------------------------------
# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
# Optional cheaper/faster model for ONLY the extraction step (e.g. claude-sonnet-4-6).
ANTHROPIC_EXTRACTION_MODEL=
ANTHROPIC_MAX_TOKENS=4096

# -----------------------------------------------------------------------------
# Google — Calendar (OAuth) + Maps (API key) [OPTIONAL]
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:4000/api/integrations/google/callback
GOOGLE_MAPS_API_KEY=

# -----------------------------------------------------------------------------
# Stripe — payment splitting [OPTIONAL]
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=gbp

# -----------------------------------------------------------------------------
# Transport for London — transit directions [OPTIONAL]
# -----------------------------------------------------------------------------
TFL_APP_KEY=

# -----------------------------------------------------------------------------
# Object storage (S3-compatible) — shared photo albums [OPTIONAL]
# -----------------------------------------------------------------------------
S3_REGION=eu-west-2
S3_BUCKET=zenemic-albums
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Set S3_ENDPOINT for non-AWS providers (Supabase/R2/MinIO); leave blank for AWS S3.
S3_ENDPOINT=
S3_PUBLIC_BASE_URL=

# -----------------------------------------------------------------------------
# Expo push [OPTIONAL] + Transactional email (Resend) [OPTIONAL]
# -----------------------------------------------------------------------------
EXPO_ACCESS_TOKEN=
RESEND_API_KEY=
EMAIL_FROM=Zenemic <no-reply@zenemic.app>

# =============================================================================
# Frontend (Expo app, main-app/) — ONLY these EXPO_PUBLIC_* values reach the app
# =============================================================================
# For a PHYSICAL PHONE (Expo Go) the API URL must be your PC's LAN IP (run
# `ipconfig`, use the IPv4 address) — NOT localhost. Android emulator: 10.0.2.2.
EXPO_PUBLIC_API_URL=http://192.168.1.100:4000
# Same Supabase project as SUPABASE_URL above, plus the PUBLIC anon key
# (Dashboard → Project Settings → API). The anon key is client-safe.
EXPO_PUBLIC_SUPABASE_URL=https://[PROJECT-REF].supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=
